<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Tech Charities — Connecting technology talent with organizations that need it most.">
  <meta name="theme-color" content="#1e3a5f">
  <!-- title is passed as a local variable from each controller via res.render() -->
  <title><%= title %> | Tech Charities</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>

  <!-- Skip link: lets keyboard/screen-reader users jump past the nav directly to content -->
  <a href="#main-content" class="skip-link">Skip to main content</a>

  <header class="site-header" role="banner">
    <div class="container">
      <div class="header-inner">

        <a href="/" class="logo" aria-label="Tech Charities — go to homepage">
          <svg class="logo-icon" aria-hidden="true" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="20" cy="20" r="20" fill="#ffffff" fill-opacity="0.15"/>
            <path d="M10 15 L20 10 L30 15 L30 28 L10 28 Z" stroke="#ffffff" stroke-width="2" fill="none"/>
            <path d="M16 22 L20 18 L24 22" stroke="#ed8936" stroke-width="2" fill="none" stroke-linecap="round"/>
          </svg>
          <span class="logo-text">Tech<strong>Charities</strong></span>
        </a>

        <!-- Mobile hamburger toggle — JS in footer handles aria-expanded toggling -->
        <button
          class="nav-toggle"
          aria-expanded="false"
          aria-controls="primary-nav"
          aria-label="Toggle navigation menu"
        >
          <span class="bar" aria-hidden="true"></span>
          <span class="bar" aria-hidden="true"></span>
          <span class="bar" aria-hidden="true"></span>
        </button>

        <nav id="primary-nav" class="primary-nav" aria-label="Primary navigation">
          <ul role="list">
            <li><a href="/">Home</a></li>
            <li><a href="/organizations">Organizations</a></li>
            <li><a href="/projects">Projects</a></li>
            <li><a href="/categories">Categories</a></li>
          </ul>
        </nav>

      </div>
    </div>
  </header>

  <main id="main-content">
